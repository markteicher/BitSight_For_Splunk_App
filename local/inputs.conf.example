#
# Example Bitsight Input Configuration
# Copy this file to inputs.conf and enable the inputs you need
#
# To enable:
# 1. Copy this file: cp inputs.conf.example inputs.conf
# 2. Configure the shared API token in setup
# 3. Review intervals and set disabled = 0 for the inputs you want
# 4. Restart Splunk: $SPLUNK_HOME/bin/splunk restart
#
# =============================================================================
# FILE
# =============================================================================
# inputs.conf.example
#
# =============================================================================
# PURPOSE
# =============================================================================
# Example BitSight input configuration
# for shared API authentication
# for input enablement
# for interval configuration
# for sourcetype alignment
#
# =============================================================================
# FILE LOCATION
# =============================================================================
# Example file:
# inputs.conf.example
#
# Runtime file:
# inputs.conf
#
# =============================================================================
# GRANULAR DOCUMENTATION SPECIFICATION
# =============================================================================
# Shared API token:
# configured once in setup
#
# Default index:
# security_bitsight
#
# Stanza format:
# [bitsight://<input_name>]
#
# Common fields:
# interval
# index
# disabled
# endpoint
# sourcetype
#
# Additional optional fields:
# risk_vectors
# days_back
#
# Input coverage:
# portfolio
# companies
# country_details
# company_requests_summary
# current_ratings
# ratings_history
# ratings_history_csv
# findings
# findings_compromised
# findings_diligence
# findings_summary
# findings_comments
# risk_vectors
# alerts
# threats
# exposed_credentials
# users
# users_quota
# users_views
# folders
# tiers
# industries
# assets
# asset_risk_matrix
# infrastructure
# infrastructure_changes
# ip_by_country
# diligence_statistics
# observations_statistics
# industry_statistics
# user_behavior_statistics
# providers
# products
# ratings_tree
# observations
# findings_summaries
# findings_statistics
# peer_analytics
# rating_distribution
# nist_csf
# preview_report
# risk_vectors_summary
#

[bitsight://portfolio]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = portfolio
sourcetype = bitsight_portfolio

[bitsight://companies]
interval = 86400
index = security_bitsight
disabled = 0
endpoint = companies
sourcetype = bitsight_company

[bitsight://country_details]
interval = 86400
index = security_bitsight
disabled = 0
endpoint = country-details
sourcetype = bitsight_country

[bitsight://company_requests_summary]
interval = 86400
index = security_bitsight
disabled = 0
endpoint = company-requests-summary
sourcetype = bitsight_company_requests

[bitsight://current_ratings]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = current-ratings
sourcetype = bitsight_ratings

[bitsight://ratings_history]
interval = 86400
index = security_bitsight
disabled = 0
endpoint = ratings-history
days_back = 365
sourcetype = bitsight_ratings_history

[bitsight://ratings_history_csv]
interval = 86400
index = security_bitsight
disabled = 0
endpoint = ratings-history-csv
sourcetype = bitsight_ratings_history_csv

[bitsight://findings]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = findings
sourcetype = bitsight_findings

[bitsight://findings_compromised]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = findings
risk_vectors = botnet_infections,spam_propagation,malware_servers,unsolicited_comm,potentially_exploited
sourcetype = bitsight_findings_compromised

[bitsight://findings_diligence]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = findings
risk_vectors = spf,dkim,ssl_certificates,ssl_configurations,open_ports,web_appsec,patching_cadence,insecure_systems,server_software,desktop_software,mobile_software,dnssec,mobile_application_security,application_security,dmarc
sourcetype = bitsight_findings_diligence

[bitsight://findings_summary]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = findings-summary
sourcetype = bitsight_findings_summary

[bitsight://findings_comments]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = finding-comments
sourcetype = bitsight_findings_comments

[bitsight://risk_vectors]
interval = 3600
index = security_bitsight
disabled = 0
endpoint = risk-vectors
sourcetype = bitsight_risk_vectors

[bitsight://alerts]
interval = 900
index = security_bitsight
disabled = 0
endpoint = alerts
sourcetype = bitsight_alerts

[bitsight://threats]
interval = 3600
index = security_bitsight
