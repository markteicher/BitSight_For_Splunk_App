#
# File:
# local/inputs.conf.example
#
# =============================================================================
# PURPOSE
# =============================================================================
# Example BitSight input configuration
# for local deployment
# for API token configuration
# for modular input enablement
# for interval configuration
# for sourcetype alignment
#
# =============================================================================
# FILE LOCATION
# =============================================================================
# App-relative path:
# local/inputs.conf.example
#
# Target runtime copy path:
# local/inputs.conf
#
# =============================================================================
# GRANULAR DOCUMENTATION SPECIFICATION
# =============================================================================
# Usage:
# 1. Copy this file:
#    cp inputs.conf.example inputs.conf
# 2. Replace:
#    YOUR_BITSIGHT_API_TOKEN_HERE
# 3. Review:
#    index values
#    collection intervals
#    disabled flags
# 4. Enable the inputs you want:
#    disabled = 0
# 5. Restart Splunk:
#    $SPLUNK_HOME/bin/splunk restart
#
# Common fields:
# api_token
# - BitSight API token
#
# interval
# - collection interval in seconds
#
# index
# - target Splunk index
#
# disabled
# - 1 = disabled
# - 0 = enabled
#
# endpoint
# - BitSight API endpoint identifier
#
# sourcetype
# - normalized sourcetype for indexed data
#
# risk_vectors
# - optional comma-separated risk vector filter
#
# days_back
# - optional historical collection window in days
#
# NOTE:
# This is an example file.
# It is intentionally disabled by default.
#
# =============================================================================
# EXAMPLE INPUT DEFINITIONS
# =============================================================================

[bitsight://portfolio]
api_token = YOUR_BITSIGHT_API_TOKEN_HERE
interval = 3600
index = security_bitsight
disabled = 1
endpoint = portfolio
sourcetype = bitsight_portfolio

[bitsight://current-ratings]
api_token = YOUR_BITSIGHT_API_TOKEN_HERE
interval = 3600
index = security_bitsight
disabled = 1
endpoint = current-ratings
sourcetype = bitsight_ratings

[bitsight://ratings-history]
api_token = YOUR_BITSIGHT_API_TOKEN_HERE
interval = 86400
index = security_bitsight
disabled = 1
endpoint = ratings-history
days_back = 365
sourcetype = bitsight_ratings_history

[bitsight://ratings-history-csv]
api_token = YOUR_BITSIGHT_API_TOKEN_HERE
interval = 86400
index = security_bitsight
