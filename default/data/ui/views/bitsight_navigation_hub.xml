            background:#ffffff;
            border:1px solid #e5e5e5;
            border-radius:8px;
            padding:22px;
            text-align:center;
            transition:all .18s ease;
          }
          .portal-tile:hover{
            box-shadow:0 4px 14px rgba(0,0,0,.18);
            transform:translateY(-2px);
          }
          .portal-icon{
            font-size:34px;
            margin-bottom:10px;
          }
          .portal-title{
            font-size:15px;
            font-weight:600;
          }
          .portal-link{
            text-decoration:none;
            color:inherit;
            display:block;
          }
          .portal-header{
            background:#f5f5f5;
            border:1px solid #d0d0d0;
            cursor:default;
            grid-column:span 4;
            font-size:16px;
            font-weight:700;
            padding:18px 22px;
          }
          .portal-static{
            cursor:default;
          }
          .portal-static:hover{
            box-shadow:none;
            transform:none;
          }
        </style>

