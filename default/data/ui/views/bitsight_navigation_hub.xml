<!--
=============================================================================
 default/data/ui/views/bitsight_navigation_hub.xml
 BitSight for Splunk App
 Navigation Hub
=============================================================================

PURPOSE

Tile-based landing page linking to the BitSight views defined in
default/data/ui/nav/default.xml.

STYLE

Matches the same portal-tile navigation design used across the other
Splunk apps.

SECTION HEADER MODEL

Collection titles from default.xml are used directly as section headers.

=============================================================================
-->
<dashboard version="1.1" theme="light">
  <label>📚 BitSight for Splunk App – Navigation Hub</label>

  <row>
    <panel>
      <html>

        <style>
          .portal-grid{
            display:grid;
            grid-template-columns:repeat(4,1fr);
            gap:22px;
            margin-top:20px;
          }
          .portal-tile{
            background:#ffffff;
            border:1px solid #e5e5e5;
            border-radius:8px;
            padding:22px;
            text-align:center;
            transition:all .18s ease;
          }
          .portal-tile:hover{
            box-shadow:0 4px 14px rgba(0,0,0,.18);
            transform:translateY(-2px);
          }
          .portal-icon{
            font-size:34px;
            margin-bottom:10px;
          }
          .portal-title{
            font-size:15px;
            font-weight:600;
          }
          .portal-link{
            text-decoration:none;
            color:inherit;
            display:block;
          }
          .portal-header{
            background:#f5f5f5;
            border:1px solid #d0d0d0;
            cursor:default;
            grid-column:span 4;
            font-size:16px;
            font-weight:700;
            padding:18px 22px;
          }
        </style>

        <div class="portal-grid">

          <!-- Top-level views -->
          <a class="portal-link" href="bitsight_overview">
            <div class="portal-tile">
              <div class="portal-icon">🧭</div>
              <div class="portal-title">Overview</div>
            </div>
          </a>

          <a class="portal-link" href="bitsight_search">
            <div class="portal-tile">
              <div class="portal-icon">🔎</div>
              <div class="portal-title">Search</div>
            </div>
          </a>

          <!-- Portfolio -->
          <div class="portal-tile portal-header">Portfolio</div>

          <a class="portal-link" href="bitsight_portfolio">
            <div class="portal-tile">
              <div class="portal-icon">🏢</div>
              <div class="portal-title">Portfolio</div>
            </div>
          </a>

          <a class="portal-link" href="bitsight_ratings_tree">
            <div class="portal-tile">
              <div class="portal-icon">🌳</div>
              <div class="portal-title">Ratings Tree</div>
            </div>
          </a>

          <a class="portal-link" href="bitsight_benchmarking">
