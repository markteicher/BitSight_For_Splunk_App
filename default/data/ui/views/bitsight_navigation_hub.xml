              <div class="portal-icon">📘</div>
              <div class="portal-title">Bitsight API Docs</div>
            </div>
          </a>

          <!-- Settings -->
          <div class="portal-tile portal-header">Settings</div>

          <a class="portal-link" href="setup">
            <div class="portal-tile">
              <div class="portal-icon">🛠️</div>
              <div class="portal-title">Setup</div>
            </div>
          </a>

          <a class="portal-link" href="data_inputs">
            <div class="portal-tile">
              <div class="portal-icon">🧩</div>
              <div class="portal-title">Data Inputs</div>
            </div>
          </a>

        </div>

      </html>
    </panel>
  </row>
</dashboard>
