          <a class="portal-link" href="bitsight_trending"><div class="portal-tile"><div class="portal-icon">🔄</div><div class="portal-title">Comparative Trending</div></div></a>
          <a class="portal-link" href="bitsight_benchmarking"><div class="portal-tile"><div class="portal-icon">🏆</div><div class="portal-title">Peer Benchmarking</div></div></a>
