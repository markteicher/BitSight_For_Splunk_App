<?xml version="1.0" encoding="UTF-8"?>
<!--
  File: default/data/ui/nav/default.xml
  Bitsight app navigation definition

  =============================================================================
  PURPOSE
  =============================================================================
  Defines the Splunk Classic XML navigation menu for the Bitsight app.

  =============================================================================
  FILE LOCATION
  =============================================================================
  App-relative path:
    default/data/ui/nav/default.xml

  Local override path:
    local/data/ui/nav/default.xml

  =============================================================================
  COLLECTION COVERAGE
  =============================================================================

  Portfolio collection covers:
  - bitsight_portfolio
  - bitsight_company
  - bitsight_country
  - bitsight_company_requests
  - bitsight_tiers
  - bitsight_industries

  Ratings collection covers:
  - bitsight_ratings
  - bitsight_ratings_history
  - bitsight_ratings_history_csv
  - bitsight_ratings_tree
  - bitsight_peer_analytics
  - bitsight_rating_distribution
  - bitsight_industry_statistics

  Findings collection covers:
  - bitsight_findings
  - bitsight_findings_compromised
  - bitsight_findings_diligence
  - bitsight_findings_summary
  - bitsight_findings_comments
  - bitsight_findings_summaries
  - bitsight_findings_statistics
  - bitsight_observations
  - bitsight_observations_statistics
  - bitsight_diligence_statistics
  - bitsight_user_behavior_statistics
  - bitsight_risk_vectors
  - bitsight_risk_vectors_summary

  Assets collection covers:
  - bitsight_assets
  - bitsight_assets_statistics
  - bitsight_infrastructure
  - bitsight_infrastructure_changes
  - bitsight_ip_by_country
  - bitsight_providers
  - bitsight_products

  Compliance collection covers:
  - bitsight_nist_csf
  - bitsight_preview_report

  Alerts collection covers:
  - bitsight_alerts

  Threats collection covers:
  - bitsight_threats

  Credentials collection covers:
  - bitsight_credentials

  Users collection covers:
  - bitsight_users
  - bitsight_users_quota
  - bitsight_users_views
  - bitsight_folders

  Operations collection covers:
  - operational monitoring views for all app data sources
-->
<nav search_view="bitsight_search" color="#1E3A5F">

  <view name="bitsight_overview" default="true"/>
  <view name="bitsight_search"/>

  <!-- Portfolio -->
  <collection label="Portfolio">
    <view name="bitsight_portfolio"/>
    <view name="bitsight_ratings_tree"/>
    <view name="bitsight_benchmarking"/>
  </collection>

  <!-- Ratings -->
  <collection label="Ratings">
    <view name="bitsight_ratings"/>
    <view name="bitsight_ratings_trending"/>
    <view name="bitsight_trending"/>
  </collection>

  <!-- Findings -->
  <collection label="Findings">
    <view name="bitsight_findings"/>
    <view name="bitsight_findings_detailed"/>
    <view name="bitsight_findings_trending"/>
    <view name="bitsight_remediation"/>
    <view name="bitsight_mttr_executive"/>
  </collection>

  <!-- Assets -->
  <collection label="Assets">
    <view name="bitsight_asset_risk_matrix"/>
  </collection>

  <!-- Compliance -->
  <collection label="Compliance">
    <view name="bitsight_nist_csf"/>
  </collection>

  <!-- Alerts -->
  <collection label="Alerts">
    <view name="bitsight_alerts"/>
  </collection>

  <!-- Threats -->
  <collection label="Threats">
    <view name="bitsight_threats"/>
  </collection>

  <!-- Credentials -->
  <collection label="Credentials">
    <view name="bitsight_exposed_credentials"/>
  </collection>

  <!-- Users -->
  <collection label="Users">
    <view name="bitsight_users"/>
    <view name="bitsight_users_access_review"/>
  </collection>

  <!-- Operations -->
  <collection label="Operations">
    <view name="bitsight_health_check"/>
    <view name="bitsight_health"/>
    <view name="bitsight_operations"/>
    <view name="bitsight_logs"/>
    <view name="bitsight_reports"/>
  </collection>

  <!-- Help -->
  <collection label="Help">
    <view name="bitsight_help"/>
  </collection>

  <!-- Settings -->
  <collection label="Settings">
    <view name="setup"/>
    <view name="data_inputs" source="unclassified"/>
  </collection>

  <a href="https://help.bitsighttech.com/hc/en-us/articles/231872628-API-Documentation-Overview">Bitsight API Docs</a>
</nav>
