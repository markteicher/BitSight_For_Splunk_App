    },
    "releaseNotes": {
      "name": "Release Notes",
      "text": "Initial release with portfolio, ratings, findings, alerts, threats, exposed credentials, users, trending dashboards, alert actions, setup, and documentation views."
    }
  },
  "platformRequirements": {
    "splunk": {
      "Enterprise": "*"
    }
  },
  "supportedDeployments": [
    "_standalone",
    "_distributed",
    "_search_head_clustering"
  ],
  "targetWorkloads": [
