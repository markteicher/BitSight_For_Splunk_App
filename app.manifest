      }
    ],
    "description": "BitSight Security Ratings integration for Splunk. Monitor security ratings, portfolio companies, alerts, findings, exposed credentials, threats, risk vectors, users, remediation activity, and operational health from the BitSightTech API.",
    "classification": {
      "intendedAudience": "Security",
      "categories": [
        "Security, Fraud & Compliance"
      ],
      "developmentStatus": "Production/Stable"
    },
